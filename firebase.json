{
    "hosting": {
        "public": "frontend/dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/api/**",
                "function": "api"
            },
            {
                "source": "/socket.io/**",
                "function": "api"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": [
        {
            "source": "backend",
            "codebase": "default",
            "ignore": [
                "venv",
                ".git",
                "instance",
                "__pycache__"
            ],
            "runtime": "python311"
        }
    ]
}